    /**
     * Registra el resultado del envío de correos electrónicos
     *
     * @param \WPMailSMTP\MailCatcher $mailcatcher Instancia del mailcatcher
     * @param bool $is_sent Si el correo fue enviado exitosamente
     */    
    function wp_mail_smtp_mailcatcher_send_after__($mailer, $_this) {
        //bh_plugins_log(['wp_mail_smtp_mailcatcher_send_after', func_get_args()], 'bh_plugins_smtp_email');
        global $current_subscription_id;
        try {

            $is_sent = $mailer->is_email_sent();
            $log_data = [
                'date' => current_time('mysql'),
                'subscription_id'=>    $current_subscription_id,
                'status' => $is_sent ? 'sent' : 'failed',
                'error' => !$is_sent ? $mailer->get_response_error() : null,
            ];
            bh_plugins_log($log_data, 'bh_plugins_smtp_email');

            global $bh_email_status;
            $bh_email_status    =   $log_data['status'] . ' - ' . $log_data['error'];
        } catch (Exception $e) {
            bh_plugins_log('Error logging email result(' . $current_subscription_id .'): ' . $e->getMessage(), 'bh_plugins_smtp_email');
        }
    }

    function wp_mail_smtp_mailcatcher_send_after($mailer, $_this) {
        //bh_plugins_log(['wp_mail_smtp_mailcatcher_send_after', func_get_args()], 'bh_plugins_smtp_email');
        global $current_subscription_id;
        try {

            $is_sent = $mailer->is_email_sent();
            $log_data = [
                'date' => current_time('mysql'),
                'subscription_id'=>    $current_subscription_id,
                'status' => $is_sent ? 'sent' : 'failed',
                'error' => !$is_sent ? $mailer->get_response_error() : null,
            ];
            bh_plugins_log($log_data, 'bh_plugins_smtp_email');

            global $bh_email_status;
            $bh_email_status['is_sent']    =   $is_sent;
            $bh_email_status['message']    =   $log_data['error'];
        } catch (Exception $e) {

            global $bh_email_status;
            $bh_email_status['is_sent']    =   false;
            $bh_email_status['message']    =   $e->getMessage();
            bh_plugins_log('Error logging email result(' . $current_subscription_id .'): ' . $e->getMessage(), 'bh_plugins_smtp_email');
        }
    }
    /**
     * Formatea las direcciones de email
     */
    private function format_addresses($addresses) {
        if (empty($addresses)) {
            return [];
        }
        
        $formatted = [];
        foreach ($addresses as $address) {
            if (is_array($address) && count($address) >= 1) {
                $formatted[] = $address[0];
            }
        }
        
        return $formatted;
    }

    /**
     * Formatea los headers
     */
    private function format_headers($headers) {
        if (empty($headers)) {
            return [];
        }
        
        $formatted = [];
        foreach ($headers as $header) {
            if (is_array($header) && count($header) >= 2) {
                $formatted[$header[0]] = $header[1];
            }
        }
        
        return $formatted;
    }
}
